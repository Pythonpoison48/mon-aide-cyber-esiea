extends base

block page
    div(class="page-mesures")
        section
            div(class="contenu")
                div(class="titre-annexe") ANNEXE
                div(class="titre")
                    h2 Recommandations complémentaires
                    p Ces recommandations vous aideront à renforcer davantage la cybersécurité de votre organisation.
                
                - const mesuresNonTechniques = mesures.filter(m => m.categorie !== 'technique')
                - const mesuresTechniques = mesures.filter(m => m.categorie === 'technique')
                
                if mesuresNonTechniques.length > 0
                    h4 Mesures Non Techniques
                    each mesure, index in mesuresNonTechniques
                        div(class="mesure")
                            div(class="titre")
                                h4 !{index + 7}. !{mesure.titre}
                            div(class="pourquoi")
                                div(class="titre") Pourquoi ?
                                div(class="libelle") !{include(mesure.pourquoi)}
                            div(class="comment")
                                div(class="titre") Comment appliquer cette recommandation ?
                                div(class="libelle") !{include(mesure.comment)}
                
                if mesuresTechniques.length > 0
                    if mesuresNonTechniques.length > 0
                        br
                    h4 Mesures Techniques
                    each mesure, index in mesuresTechniques
                        div(class="mesure")
                            div(class="titre")
                                h4 !{index + 7 + mesuresNonTechniques.length}. !{mesure.titre}
                            div(class="pourquoi")
                                div(class="titre") Pourquoi ?
                                div(class="libelle") !{include(mesure.pourquoi)}
                            div(class="comment")
                                div(class="titre") Comment appliquer cette recommandation ?
                                div(class="libelle") !{include(mesure.comment)}

